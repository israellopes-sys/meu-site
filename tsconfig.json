{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",

    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,

    "resolveJsonModule": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },

  "include": [
    "controllers/**/*",
    "models/**/*",
    "routes/**/*",
    "public/js/**/*",
    "prisma.ts",
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}